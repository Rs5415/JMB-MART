{
  "entities": {
    "users": {
      "title": "User",
      "description": "Application users and their roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string", "description": "Mandatory unique mobile number" },
        "role": { "type": "string", "enum": ["user", "admin", "delivery"] },
        "location": { 
          "type": "object", 
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        },
        "savedAddresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "houseNumber": { "type": "string" },
              "village": { "type": "string" },
              "phone": { "type": "string" },
              "pincode": { "type": "string" },
              "landmark": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "phoneNumber"]
    },
    "orders": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "address": { "type": "object" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "landmark": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "assigned", "out_for_delivery", "delivered", "cancelled"] },
        "deliveryPersonId": { "type": "string" },
        "otp": { "type": "string", "description": "4-digit OTP for delivery verification" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "address", "status", "createdAt"]
    },
    "products": {
      "title": "Product",
      "description": "Store products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "inStock": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image", "description"]
    },
    "banners": {
      "title": "Banner",
      "description": "Marketing banners and offers",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "highlight": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "searchQuery": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subtitle", "highlight", "description", "image", "searchQuery", "color"]
    },
    "reviews": {
      "title": "Review",
      "description": "Product reviews and ratings",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Order documents"
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Product documents"
    },
    "/banners/{bannerId}": {
      "schema": "banners",
      "description": "Offer banner documents"
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Product review documents"
    },
    "/carts/{userId}": {
      "schema": "object",
      "description": "User shopping carts"
    },
    "/phoneNumbers/{phoneNumber}": {
      "schema": "object",
      "description": "Mapping of phone numbers to user UIDs to ensure uniqueness"
    }
  }
}
