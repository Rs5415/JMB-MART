rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User name
    //   - role: string (required, ['user', 'admin']) - User role
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - items: list (required) - List of products
    //   - total: number (required) - Order total
    //   - address: map (required) - Delivery address
    //   - landmark: string (optional) - Delivery landmark
    //   - status: string (required, ['pending', 'cancelled', 'delivered']) - Order status
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - image: string (required)
    //   - description: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "archanasharma993151@gmail.com");
    }

    function isDeliveryPerson() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'delivery';
    }

    function isNotBlocked() {
      return !isAuthenticated() || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'phoneNumber', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.phoneNumber is string &&
             data.phoneNumber.matches("^[0-9]{10}$") &&
             data.role in ['user', 'admin', 'delivery'] &&
             data.createdAt is timestamp &&
             (!('isBlocked' in data) || data.isBlocked is bool) &&
             (!('location' in data) || (data.location is map && data.location.keys().hasAll(['lat', 'lng', 'updatedAt'])));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'address', 'status', 'createdAt']) &&
             data.userId is string &&
             data.items is list &&
             data.total is number &&
             data.address is map &&
             data.status in ['pending', 'assigned', 'out_for_delivery', 'delivered', 'cancelled'] &&
             data.createdAt is timestamp &&
             (!('deliveryPersonId' in data) || data.deliveryPersonId is string) &&
             (!('otp' in data) || (data.otp is string && data.otp.matches("^[0-9]{4}$")));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image', 'description']) &&
             data.name is string &&
             data.price is number &&
             data.category is string &&
             data.image is string &&
             data.description is string &&
             (!('status' in data) || data.status in ['available', 'out_of_stock', 'unavailable']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && isNotBlocked(); // Allow users to see delivery person info/location
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() || 
                      (isOwner(userId) && isNotBlocked() && isValidUser(request.resource.data) &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.get('isBlocked', false) == resource.data.get('isBlocked', false));
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && isNotBlocked() && (resource.data.userId == request.auth.uid || isAdmin() || resource.data.deliveryPersonId == request.auth.uid);
      allow create: if isAuthenticated() && isNotBlocked() && isValidOrder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || 
                      (isOwner(resource.data.userId) && isNotBlocked() && request.resource.data.status == 'cancelled' && resource.data.status == 'pending') ||
                      (isDeliveryPerson() && isNotBlocked() && resource.data.deliveryPersonId == request.auth.uid && 
                       ((request.resource.data.status == 'out_for_delivery' && resource.data.status == 'assigned') ||
                        (request.resource.data.status == 'delivered' && resource.data.status == 'out_for_delivery' && request.resource.data.otp == resource.data.otp)));
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId) && isNotBlocked();
    }

    match /phoneNumbers/{phoneNumber} {
      allow read: if isAuthenticated() && isNotBlocked();
      allow create: if isAuthenticated() && isNotBlocked() && 
                      request.resource.data.uid == request.auth.uid &&
                      phoneNumber.matches("^[0-9]{10}$");
      allow update, delete: if false; // Phone numbers are immutable once linked
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
