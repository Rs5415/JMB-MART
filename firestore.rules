rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUnblocked() {
      return !isSignedIn() || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) != true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "archanasharma993151@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validations
    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'role', 'phoneNumber', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() <= 256 &&
             data.role in ['user', 'admin', 'delivery'] &&
             data.phoneNumber is string &&
             data.phoneNumber.matches("^[0-9]{10}$") &&
             data.createdAt == request.time &&
             (!('isBlocked' in data) || data.isBlocked is bool);
    }

    function isValidOrder(data) {
      let requiredFields = ['userId', 'items', 'total', 'address', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.items.size() <= 100 &&
             data.total is number &&
             data.total >= 0 &&
             data.address is map &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      let requiredFields = ['name', 'price', 'category', 'image', 'description'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string && data.image.size() <= 1000 &&
             data.description is string && data.description.size() <= 2000;
    }

    function isValidBanner(data) {
      let requiredFields = ['title', 'subtitle', 'highlight', 'description', 'image', 'searchQuery', 'color'];
      return data.keys().hasAll(requiredFields) &&
             data.title is string && data.title.size() <= 100 &&
             data.subtitle is string && data.subtitle.size() <= 200 &&
             data.highlight is string && data.highlight.size() <= 100 &&
             data.description is string && data.description.size() <= 500 &&
             data.image is string && data.image.size() <= 1000 &&
             data.searchQuery is string && data.searchQuery.size() <= 100 &&
             data.color is string;
    }

    function isValidReview(data) {
      let requiredFields = ['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.productId is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // 3. Collection Rules
    
    match /users/{userId} {
      // Admins can list and get any user. Owners can get their own.
      // Split read to avoid query failures.
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isValidUser(request.resource.data) && 
                      (request.resource.data.role in ['user', 'delivery'] || isAdmin());
      
      allow update: if (isAdmin() || (isOwner(userId) && isUnblocked())) && (
        // Action: Update Profile (Self)
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'location', 'role']) && 
         (request.resource.data.role == resource.data.role || (request.resource.data.role == 'delivery' && resource.data.role == 'user'))) ||
        // Action: Administrative
        isAdmin()
      );
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && isUnblocked() && (resource.data.userId == request.auth.uid || isAdmin() || resource.data.deliveryPersonId == request.auth.uid);
      allow list: if isSignedIn() && isUnblocked() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.deliveryPersonId == request.auth.uid);
      
      allow create: if isSignedIn() && isUnblocked() && isValidOrder(request.resource.data);
      
      allow update: if (isAdmin() || (isSignedIn() && isUnblocked())) && (
        // Action: Cancel
        (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // Action: Assign (Admin)
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deliveryPersonId', 'status', 'otp'])) ||
        // Action: Delivery Partner Progress
        (resource.data.deliveryPersonId == request.auth.uid && (
          (request.resource.data.status == 'out_for_delivery' && resource.data.status == 'assigned' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
          (request.resource.data.status == 'delivered' && resource.data.status == 'out_for_delivery' && request.resource.data.otp == resource.data.otp && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        )) ||
        // Action: Full Admin Override
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp);
      allow delete: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow create, update: if isAdmin() && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp);
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isUnblocked() && isValidReview(request.resource.data);
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId) && isUnblocked();
    }

    match /phoneNumbers/{phoneNumber} {
      allow read: if isSignedIn() && isUnblocked();
      allow create: if isSignedIn() && isUnblocked() && 
                      phoneNumber.matches("^[0-9]{10}$") &&
                      request.resource.data.uid == request.auth.uid;
    }
  }
}
