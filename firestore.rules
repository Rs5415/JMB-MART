rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User name
    //   - role: string (required, ['user', 'admin']) - User role
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - items: list (required) - List of products
    //   - total: number (required) - Order total
    //   - address: map (required) - Delivery address
    //   - landmark: string (optional) - Delivery landmark
    //   - status: string (required, ['pending', 'cancelled', 'delivered']) - Order status
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - image: string (required)
    //   - description: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "archanasharma993151@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'address', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.total is number &&
             data.address is map &&
             data.status in ['pending', 'cancelled', 'delivered'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image', 'description']) &&
             data.name is string &&
             data.price is number &&
             data.category is string &&
             data.image is string &&
             data.description is string &&
             (!('status' in data) || data.status in ['available', 'out_of_stock', 'unavailable']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
